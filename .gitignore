*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.env*
# uv
uv.lock

# Tooling caches
.ruff_cache/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Editors / OS
.vscode/
